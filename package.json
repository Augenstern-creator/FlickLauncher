{
  "name": "flick-launcher",
  "version": "1.2.0",
  "description": "桌面快速启动器 - 快速启动你的常用软件和文件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "keywords": [
    "flick-launcher",
    "launcher",
    "desktop"
  ],
  "author": "Flick Launcher Team",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "conf": "^10.2.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.flicklauncher.app",
    "productName": "Flick Launcher",
    "directories": {
      "output": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Augenstern-creator",
        "repo": "FlickLauncher"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "renderer/icons/default-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
